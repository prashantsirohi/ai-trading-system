# Optimization recipe scaffolded by `ai-trading-optimize init $name`.
#
# Edit window, fitness weights, acceptance gates, and stopping rules to suit
# your study. ``baseline_pack_path`` may be a bare name (resolved to
# ``config/strategies/<name>.yaml``) or a literal path.
name: $name
strategy_id: $strategy_id
# Bare name → resolved to config/strategies/<value>.yaml by resolve_baseline_path.
# init scaffolds the rule pack at config/strategies/${name}_v1.yaml.
baseline_pack_path: ${name}_v1
from_date: "$from_date"
to_date: "$to_date"
exchange: NSE
benchmark:
  symbol: UNIV_TOP1000
  source: index_catalog
  blend: 0.35
starting_equity: 1000000.0
commission_bps: 10.0
slippage_bps: 35.0
seed: 42
walkforward:
  train_months: 12
  validation_months: 3
  step_months: 3
fitness_weights:
  cagr: 0.25
  sharpe: 0.20
  sortino: 0.10
  win_rate: 0.05
  drawdown_penalty: 0.30
  turnover_penalty: 0.10
acceptance:
  min_fitness_improvement: 0.01
  max_mdd_ratio_vs_champion: 1.10
  min_trades_per_year: 40.0
  min_fold_improvement_rate: 0.60
  worst_fold_min_return_vs_benchmark: true
  worst_fold_max_mdd_ratio_vs_baseline: 1.10
  require_no_zero_trade_fold: true
stopping:
  max_trials: 50
  patience: 8
  max_runtime_minutes: 120
description: >
  Scaffolded recipe for $name. Tune stopping/acceptance before launch.
