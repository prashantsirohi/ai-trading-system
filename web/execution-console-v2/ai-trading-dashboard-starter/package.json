{
  "name": "ai-trading-dashboard-starter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "tsc -b --pretty false",
    "test": "vitest run",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "gen:api": "openapi-typescript ./openapi.snapshot.json -o ./src/types/api.gen.ts",
    "check:api": "PYTHONPATH=../../../src ../../../.venv/bin/python ../../../scripts/export_phase4_openapi.py --check",
    "gen:api:live": "openapi-typescript http://127.0.0.1:8090/openapi.json -o ./src/types/api.gen.ts"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-table": "^8.21.3",
    "framer-motion": "^12.12.1",
    "lightweight-charts": "^5.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.1",
    "recharts": "^2.15.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "axe-core": "4.11.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.4.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.6.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
}
