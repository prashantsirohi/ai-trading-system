# Execution Console v2 — environment configuration
#
# Copy to `.env.local` and adjust per environment. All variables must be
# prefixed VITE_ to be exposed to the browser bundle (Vite convention).

# When true the app falls back to in-memory mocks for every fetch. Useful
# for FE-only development without a backend.
VITE_USE_MOCK_API=false

# Absolute base URL for the FastAPI execution backend. Leave empty to use
# the dev-server proxy (Vite forwards /api/* to VITE_EXECUTION_PROXY_TARGET).
# In production builds this MUST be set to the deployed API origin.
VITE_EXECUTION_API_BASE_URL=

# API key sent as the `x-api-key` header. Must match the value the FastAPI
# server reads from the EXECUTION_API_KEY environment variable.
VITE_EXECUTION_API_KEY=local-dev-key

# Vite-only: where the dev server proxies /api/* requests when
# VITE_EXECUTION_API_BASE_URL is empty. Ignored in production builds.
VITE_EXECUTION_PROXY_TARGET=http://127.0.0.1:8090

# Default react-query refetchInterval (in milliseconds) for live snapshots
# such as the pipeline workspace and ranking page. 0 disables auto-refresh.
VITE_DEFAULT_REFETCH_INTERVAL_MS=60000
