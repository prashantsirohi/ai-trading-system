    "/api/execution/stocks/{symbol}/ohlcv": {
      "get": {
        "description": "Return OHLCV + delivery candles for ``symbol`` in ascending time order.",
        "operationId": "execution_stock_ohlcv_api_execution_stocks__symbol__ohlcv_get",
        "parameters": [
          {
            "in": "path",
            "name": "symbol",
            "required": true,
            "schema": {
              "title": "Symbol",
              "type": "string"
            }
          },
          {
            "description": "Inclusive lower bound (ISO date, ``YYYY-MM-DD``).",
            "in": "query",
            "name": "from",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Inclusive lower bound (ISO date, ``YYYY-MM-DD``).",
              "title": "From"
            }
          },
          {
            "description": "Inclusive upper bound (ISO date, ``YYYY-MM-DD``).",
            "in": "query",
            "name": "to",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Inclusive upper bound (ISO date, ``YYYY-MM-DD``).",
              "title": "To"
            }
          },
          {
            "description": "Candle interval; only ``daily`` is supported today.",
            "in": "query",
            "name": "interval",
            "required": false,
            "schema": {
              "default": "daily",
              "description": "Candle interval; only ``daily`` is supported today.",
              "title": "Interval",
              "type": "string"
            }
          },
          {
            "description": "Maximum candles to return; keeps the most recent rows.",
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "anyOf": [
                {
