# Copy to .env and edit. Values shown are defaults / examples.

# --- Storage roots ----------------------------------------------------------
# Relocate large trees (DuckDB files, parquet, pipeline runs, optuna, reports,
# logs, models) onto an external SSD. Leave unset to use the in-repo layout
# (data/, reports/, logs/, models/).
#
# Note: data/masterdata.db and data/NSE_Companies.xlsx are git-tracked and
# stay in the repo regardless of DATA_ROOT.
#DATA_ROOT=/Volumes/MacData/Trading/data
#REPORTS_ROOT=/Volumes/MacData/Trading/reports
#LOGS_ROOT=/Volumes/MacData/Trading/logs
#MODELS_ROOT=/Volumes/MacData/Trading/models

# --- Execution API ----------------------------------------------------------
#EXECUTION_API_KEY=

# --- Data domain ------------------------------------------------------------
# operational (default) or research
#DATA_DOMAIN=operational
