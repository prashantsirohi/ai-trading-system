# Auto detect text files
* text=auto

# Force specific line endings
*.py text eol=lf
*.ps1 text eol=crlf
*.md text eol=lf
*.txt text eol=lf
*.csv text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.env text eol=lf
*.example text eol=lf

# Binary files — don't touch
*.parquet binary
*.db binary
*.duckdb binary
